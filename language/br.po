#, python-brace-format
msgid ""
"<p>Hi,</p>\n"
"<p>A new user, {user_name}, is registering on <a "
"href=\"{site_url}\">{site_title}</a> ({main_title}).</p>\n"
"<p>You may moderate this email: {user_email}.</p>\n"
"<p>This is an automatic message.</p>"
msgstr ""
"Demat,\n"
"Un implijer nevez, {user_name}, zo o'n em enskrivañ war <a "
"href=\"{site_url}\">{site_title} ({main_title}).\n"
"Gallout a rit moderañ ar postel-mañ : {user_email}.\n"
"Ur gemennadenn emgefre eo hemañ"

#: config/module.config.php:350 config/module.config.php:423
#, python-brace-format
msgid ""
"<p>Hi {user_name},</p>\n"
"<p>You have registered for an account on <a "
"href=\"{site_url}\">{site_title}</a> ({main_title}).</p>\n"
"<p>Please confirm your registration by following this link: <a "
"href=\"{token_url}\"> {token_url}</a></p>\n"
"<p>If you did not request to join {main_title} / {site_title}, please "
"disregard this email.</p>"
msgstr ""
"Demat {user_name},\n"
"En em enskrivet oc'h evit ur gont war <a href=\"{site_url}\">{site_title} "
"({main_title}).\n"
"Kadarnait hoc'h enskrivadur mar plij en ur heuliañ al liamm-mañ : <a "
"href=\"{token_url}\"> {token_url}\n"
"Ma n'hoc'h eus ket goulennet dont e-barzh {main_title} / {site_title}, mar "
"plij, lezit a-gostez ar postel-mañ"

#: config/module.config.php:358 config/module.config.php:431
#, python-brace-format
msgid ""
"<p>Hi {user_name},</p>\n"
"<p>We are happy to open your account on <a "
"href=\"{site_url}\">{site_title}</a> ({main_title}).</p>\n"
"<p>Please confirm your email by following this link: <a "
"href=\"{token_url}\">{token_url}</a>.</p>\n"
"<p>You can now log in and discover the site.</p>"
msgstr ""
"Demat {user_name},\n"
"Laouen omp o tigeriñ ho kont war <a href=\"{site_url}\">{site_title} "
"({main_title}).\n"
"Kadarnait ho postel mar plij en ur heuliañ al liamm-mañ : <a "
"href=\"{token_url}\">{token_url}.\n"
"Gallout a rit bremañ kevreañ ha dizoleiñ al lec'hienn"

#: config/module.config.php:366 config/module.config.php:439
#, python-brace-format
msgid ""
"<p>Hi {user_name},</p>\n"
"<p>You have requested to update email on <a "
"href=\"{site_url}\">{site_title}</a> ({main_title}).</p>\n"
"<p>Please confirm your email by following this link: <a "
"href=\"{token_url}\">{token_url}</a>.</p>\n"
"<p>If you did not request to update your email on {main_title}, please "
"disregard this email.</p>"
msgstr ""
"Demat {user_name},\n"
"Goulennet hoc'h eus hizivaat ho postel war <a "
"href=\"{site_url}\">{site_title} ({main_title}).\n"
"Kadarnait ho postel mar plij en ur heuliañ al liamm-mañ : <a "
"href=\"{token_url}\">{token_url}.\n"
"Ma n'hoc'h eus ket goulennet hizivaat ho postel war {main_title}, mar plij, "
"na rit ket van ouzh ar postel-mañ"

